# ── Website: lead capture form ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_LEAD_ENDPOINT=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Outreach pipeline: lead ingestion ────────────────────────────────────────
# Set ONE of these to let the monitor agent pull real leads.
#
# Option A: Gradeum API
GRADEUM_API_URL=https://api.gradeum.io/api/v1
GRADEUM_API_KEY=
#
# Option B: Supabase direct
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Outreach pipeline: email verification (optional) ─────────────────────────
# Configure ONE to enable deliverability validation during targeting.
ZEROBOUNCE_API_KEY=
NEVERBOUNCE_API_KEY=

# ── Outreach pipeline: email sending ─────────────────────────────────────────
# Configure ONE provider to enable real sends.
#
# Option 1: SendGrid
SENDGRID_API_KEY=
#
# Option 2: Postmark
POSTMARK_SERVER_TOKEN=
#
# Option 3: AWS SES
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
#
# Option 4: SMTP (Gmail, Outlook, custom)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ── Outreach pipeline: sender identity ───────────────────────────────────────
GRADEUM_FROM_EMAIL=outreach@gradeum.io
GRADEUM_FROM_NAME=Gradeum
GRADEUM_REPLY_TO=
